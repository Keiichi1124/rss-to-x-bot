# X API credentials for OAuth 2.0 user-context posting.
# Create these in the X Developer Portal and keep real values out of git.
X_API_KEY="YOUR_X_API_KEY"
X_API_SECRET="YOUR_X_API_SECRET"
X_ACCESS_TOKEN="YOUR_X_ACCESS_TOKEN"
X_REFRESH_TOKEN="YOUR_X_REFRESH_TOKEN"

# RSS source. The bot currently reads one feed URL from RSS_FEED_URL.
RSS_FEED_URL="https://example.com/feed.xml"

# Optional URL shortener.
# BITLY_ACCESS_TOKEN="YOUR_BITLY_ACCESS_TOKEN"

# Optional post formatting.
DEFAULT_HASHTAG="#NewsDigest"

# Optional health-check port for loop mode.
HEALTH_CHECK_PORT="8080"
